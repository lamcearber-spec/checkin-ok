                  xmlns:v11="http://socialsecurity.be/presenceregistration/schemas/v1">
   <soapenv:Header/>
   <soapenv:Body>
      <v1:RegisterPresencesRequest>
         <v1:CIAOPresenceDeclaration>
            <v11:INSS>92051011122</v11:INSS>
            <v11:CompanyID>0412345678</v11:CompanyID>
            <v11:WorkPlaceId>W999888777</v11:WorkPlaceId>
            <v11:WorkPeriods>
               <v11:Period>
                  <v11:Action>IN</v11:Action>
                  <v11:Timestamp>2026-03-16T07:00:00+01:00</v11:Timestamp>
               </v11:Period>
               <v11:Period>
                  <v11:Action>OUT</v11:Action>
                  <v11:Timestamp>2026-03-16T12:00:00+01:00</v11:Timestamp>
